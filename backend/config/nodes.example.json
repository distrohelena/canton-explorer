{
  "debugger": {
    "localDarDirectory": "./debug-dars"
  },
  "tokenMetadata": {
    "nameKeys": ["name"],
    "symbolKeys": ["symbol"]
  },
  "nodes": [
    {
      "id": "participant-1",
      "label": "Participant 1",
      "role": "participant",
      "mode": "pqs_with_grpc",
      "ledgerLabel": "Retail Ledger",
      "pqs": {
        "connectionUriEnv": "PARTICIPANT_1_PQS_URL",
        "schema": "public"
      },
      "grpc": {
        "ledgerTarget": "localhost:5012",
        "ledgerAdminTarget": "localhost:5012",
        "participantAdminTarget": "localhost:5013",
        "useTls": false,
        "connectTimeoutMs": 5000,
        "auth": {
          "kind": "self_signed_es256",
          "sub": "ledger-api-user",
          "aud": "https://canton.network.global",
          "privateKeyEnv": "CANTON_ES256_PRIVATE_JWK"
        }
      },
      "polling": {
        "intervalMs": 15000,
        "staleAfterMs": 45000
      }
    }
  ]
}
