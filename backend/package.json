{
  "name": "@distrohelena/canton-explorer",
  "version": "0.1.2",
  "description": "Read-only operations explorer for Canton participant nodes and PQS-backed ledgers.",
  "author": "",
  "license": "Apache-2.0",
  "main": "dist/src/main.js",
  "bin": {
    "canton-explorer": "bin/canton-explorer.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin",
    "config/nodes.example.json",
    "dist",
    ".env.example",
    "README.md"
  ],
  "scripts": {
    "build": "nest build",
    "build:package": "node ./scripts/prepack.mjs",
    "dar:debug": "node ./scripts/build-debug-dar.mjs",
    "dar:prepare-workspace": "node ./scripts/prepare-debug-dars-from-workspace.mjs",
    "dar:source-map": "node ./scripts/generate-daml-source-map.mjs",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "sdk:local": "node ./scripts/link-local-sdk.mjs",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "prepack": "node ./scripts/prepack.mjs",
    "pack:dry-run": "npm pack --dry-run",
    "debug:list-local-parties": "NODE_OPTIONS=--experimental-vm-modules ts-node ./scripts/list-local-parties.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:cov": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:debug": "NODE_OPTIONS=--experimental-vm-modules node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "NODE_OPTIONS=--experimental-vm-modules jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@distrohelena/canton-typescript-sdk": "^0.1.3",
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "dotenv": "^17.4.2",
    "pg": "^8.22.0",
    "protobufjs": "^7.5.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*(\\.|-)spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
